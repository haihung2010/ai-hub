APP_PORT=8000
LOG_LEVEL=INFO

LOCAL_PROVIDER=llama_cpp
LLAMA_CPP_BASE_URL=http://localhost:8080
LLAMA_CPP_OPENAI_URL=http://localhost:8080/v1

DEFAULT_MODEL=local-gemma4-e4b-q4
LITE_MODEL=local-gemma4-e4b-q4
DEFAULT_NUM_CTX=8192
LITE_NUM_CTX=32768
MAX_HISTORY_MESSAGES=20
LITE_MAX_HISTORY_MESSAGES=60
REQUEST_TIMEOUT_SECONDS=60
GPU_CONCURRENCY=1

API_KEY=change-me
RATE_LIMIT_PER_MINUTE=30
SECURITY_LOG_FILE=security.log
ALLOWED_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:5173","http://127.0.0.1:8000","https://htechlabsvn.com","https://api-aiserver.htechlabsvn.com"]

SUMMARY_THRESHOLD=20
SUMMARY_MODEL=local-gemma4-e4b-q4

ENABLE_STRUCTMEM=false
STRUCTMEM_EXTRACTION_THRESHOLD=8
STRUCTMEM_EXTRACTION_MODEL=local-gemma4-e4b-q4
STRUCTMEM_CONSOLIDATION_MODEL=local-gemma4-e4b-q4
STRUCTMEM_MAX_EPISODIC=4
STRUCTMEM_MAX_SEMANTIC=6
STRUCTMEM_MAX_RELATIONAL=4
STRUCTMEM_MAX_PROCEDURAL=4
STRUCTMEM_MAX_CONSOLIDATED=3
STRUCTMEM_DEBUG_INCLUDE_TRACE=false

ENABLE_WEB_SEARCH_TOOL=true
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=8
GOOGLE_API_KEY=
GOOGLE_SEARCH_CX=

ENABLE_CREW_AGENTS=false
CREW_MODEL=local-gemma4-e4b-q4
